FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    git \
    gh \
    curl \
    wget \
    unzip \
    fish \
    python3 \
    ca-certificates \
    gnupg \
    direnv \
    nano \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 LTS via nodesource
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# install agent browser
RUN npx playwright install-deps
RUN npm install -g agent-browser
# npx --yes agent-browser install --with-deps
RUN agent-browser install
RUN agent-browser install --with-deps

# OpenCode CLI
RUN curl -fsSL https://opencode.ai/install | bash

# Go and ralphex
ARG GO_VERSION=1.26.1
ARG GO_TARBALL_SHA256=031f088e5d955bab8657ede27ad4e3bc5b7c1ba281f05f245bcc304f327c987a
ARG RALPHEX_VERSION=v0.20.0
RUN wget -q "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" -O /tmp/go.tgz \
    && echo "${GO_TARBALL_SHA256}  /tmp/go.tgz" | sha256sum -c - \
    && tar -C /usr/local -xzf /tmp/go.tgz \
    && rm -f /tmp/go.tgz
ENV GOROOT=/usr/local/go
ENV GOPATH=/root/go
ENV PATH="${GOROOT}/bin:${GOPATH}/bin:${PATH}"
RUN go install github.com/umputun/ralphex/cmd/ralphex@${RALPHEX_VERSION}

# Starship prompt
RUN curl -fsSL https://starship.rs/install.sh | sh -s -- -y

# Add CLI tools to PATH
ENV PATH="/root/.opencode/bin:${PATH}"

# Set fish as default shell
RUN chsh -s /usr/bin/fish

CMD ["fish"]
