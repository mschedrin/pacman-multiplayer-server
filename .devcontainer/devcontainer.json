{
  "build": {
    "dockerfile": "Dockerfile.opencode"
  },
  "initializeCommand": "mkdir -p .devcontainer/home/.config/fish",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "runArgs": ["--name", "${localWorkspaceFolderBasename}_devcontainer"],
  "mounts": [
    // "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind",
    // "source=${localEnv:HOME}/.claude.json,target=/root/.claude.json,type=bind",
    // "source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind",
    // "source=${localEnv:HOME}/.config/opencode,target=/root/.config/opencode,type=bind",
    // "source=${localEnv:HOME}/.local/share/opencode,target=/root/.local/share/opencode,type=bind",
    // "source=${localEnv:HOME}/.local/state/opencode,target=/root/.local/state/opencode,type=bind",
    "source=${localWorkspaceFolder}/.devcontainer/home/.config/fish,target=/root/.config/fish,type=bind"
  ],
  "containerEnv": {
    "TERM": "xterm-256color",
    "IS_SANDBOX": "1"
  },
  "forwardPorts": [8000],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "fish",
        "git.useIntegratedAskPass": false,
        "git.terminalAuthentication": false
      }
    }
  }
}
