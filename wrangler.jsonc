{
  "name": "pacman-server",
  "main": "src/index.ts",
  "compatibility_date": "2024-04-03",
  "dev": {
    "port": 8000
  },
  "vars": {
    // For local dev/testing only; production uses: npx wrangler secret put ADMIN_API_KEY
    "ADMIN_API_KEY": "test-admin-key"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "GAME_ROOM",
        "class_name": "GameRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GameRoom"]
    }
  ]
}
